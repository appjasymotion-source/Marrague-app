<!DOCTYPE html>
<html lang="pt-mz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Marrague Niassa</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: sans-serif; }
        body, html { height: 100%; width: 100%; overflow: hidden; background-color: #000; }

        /* Usei um link direto para a imagem não dar erro */
        .bg-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-image: url('https://images.unsplash.com/photo-1506744038136-46273834b3fb?q=80&w=1000');
            background-size: cover; background-position: center; z-index: 1;
            transition: filter 1.2s ease, transform 1.2s ease;
        }
        .blurred { filter: blur(12px) brightness(0.6); transform: scale(1.1); }

        .app-container { position: relative; z-index: 10; height: 100%; width: 100%; }
        .screen { display: none; height: 100%; width: 100%; flex-direction: column; align-items: center; justify-content: center; color: white; padding: 20px; text-align: center; }
        .active { display: flex; }

        .logo { font-size: 58px; font-weight: 800; color: #e5b94c; margin-bottom: 40px; text-shadow: 0 4px 15px rgba(0,0,0,0.5); }

        .input-box { width: 100%; max-width: 320px; }
        input {
            width: 100%; background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
            padding: 20px; border-radius: 40px; color: white; margin-bottom: 15px; outline: none; backdrop-filter: blur(10px); font-size: 17px;
        }

        .btn-entrar {
            width: 100%; background: #000; color: white; border: none; padding: 22px;
            border-radius: 40px; font-weight: bold; cursor: pointer; text-transform: uppercase; font-size: 16px; margin-top: 15px;
        }

        .links { margin-top: 30px; font-size: 15px; line-height: 2.2; color: #ddd; }
        .version { position: absolute; bottom: 30px; font-size: 11px; opacity: 0.6; width: 100%; }
    </style>
</head>
<body>
    <div id="bg" class="bg-overlay"></div>
    <div class="app-container">
        <div id="splash" class="screen active"><h1 class="logo">marrague</h1></div>
        <div id="login" class="screen">
            <h1 class="logo" style="font-size: 48px;">marrague</h1>
            <div class="input-box">
                <input type="text" placeholder="Jasy">
                <input type="password" placeholder="···">
                <button class="btn-entrar">ENTRAR</button>
                <div class="links">
                    <p>Esqueceu a senha?</p>
                    <p>Criar conta</p>
                </div>
            </div>
            <div class="version">Versão 1.2.0 - Marrague Niassa Delivery & Services</div>
        </div>
    </div>
    <script>
        setTimeout(() => {
            document.getElementById('splash').classList.remove('active');
            document.getElementById('login').classList.add('active');
            document.getElementById('bg').classList.add('blurred');
        }, 3000);
    </script>
</body>
</html>
